{
  "name": "@kontafy/api",
  "version": "0.1.0",
  "private": true,
  "description": "Kontafy API Server — NestJS 11",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@kontafy/db": "workspace:*",
    "@kontafy/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^8.0.0",
    "@nestjs/bull": "^11.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "zod": "^3.24.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.25.0",
    "puppeteer": "^23.10.0",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "exceljs": "^4.4.0",
    "archiver": "^7.0.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^22.10.0",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/multer": "^1.4.12",
    "@types/archiver": "^6.0.3",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "nodemon": "^3.1.0",
    "source-map-support": "^0.5.21"
  }
}
