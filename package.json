{
  "name": "kontafy",
  "version": "0.1.0",
  "private": true,
  "description": "Kontafy — Cloud-native accounting platform for Indian businesses",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @kontafy/db prisma generate",
    "db:migrate": "pnpm --filter @kontafy/db prisma migrate dev",
    "db:seed": "pnpm --filter @kontafy/db prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  }
}
